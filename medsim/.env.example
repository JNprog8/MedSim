# MedSim - Configuración de Entorno
# Copia este archivo como .env y completa los valores.

# --- Configuración General ---
PATIENTS_DIR=./patients
DB_PATH=./medsim.db
LOG_LEVEL=INFO

# --- LLM Backend (OpenAI Compatible o Ollama) ---
PATIENT_LLM_URL=http://localhost:11434/v1
PATIENT_LLM_API_KEY=ollama
PATIENT_LLM_MODEL=llama3
OLLAMA_URL=http://host.docker.internal:11434

# --- Speech-to-Text (STT) ---
STT_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash
STT_API_KEY=tu_api_key_de_gemini
STT_MODEL=gemini-2.0-flash

# --- Text-to-Speech (TTS) ---
TTS_API_URL=https://api.elevenlabs.io/v1/text-to-speech
TTS_API_KEY=tu_api_key_de_elevenlabs
TTS_VOICE_ID=pNInz6obpg8ndclK7BJ3
TTS_MODEL_ID=eleven_multilingual_v2
TTS_LANGUAGE=es
